{
  "_doc": "MQTT Payload Reference — Digital Signage (Format Tunggal)",
  "_topic": "signage/<device_id>/<section>/content",
  "_topic_contoh": "signage/smkn-1-denpasar/news/content",

  "_format_tunggal": {
    "id":            "uuid dari server (string)",
    "content_id":    "id record di DB — null untuk add, isi untuk update/delete (integer|null)",
    "type":          "news | agenda | template | advertisement | config | system",
    "action":        "add | update | delete | clear_all | reload",
    "publisher":     "campus | school",
    "title":         "template_name / ad_name / judul agenda / label (string|null)",
    "content":       "isi berita (news) / value config — alias untuk field value (string|null)",
    "description":   "deskripsi panjang — untuk agenda (string|null)",
    "key":           "nama key config — wajib untuk type=config (string|null)",
    "value":         "nilai config — untuk type=config, bisa juga pakai 'content' (string|null)",
    "media_type":    "text | image | video",
    "media_path":    "path lokal penyimpanan file di Raspberry Pi (string|null)",
    "media_url":     "URL download media dari server, otomatis didownload ke media_path (string|null)",
    "duration":      "detik tampil — untuk template (image) dan advertisement (integer|null)",
    "display_order": "urutan rotasi — untuk template dan advertisement (integer|null)",
    "trigger_time":  "detik sebelum iklan muncul — khusus advertisement (integer|null)",
    "event_date":    "tanggal acara teks bebas: 'Rabu, 14 Februari 2026' (string|null)",
    "event_time":    "jam acara HH:MM: '08:00' (string|null)",
    "position":      "urutan di sidebar agenda (integer|null)",
    "is_active":     "1 = aktif, 0 = nonaktif (integer, default 1)",
    "_sentAt":       "timestamp ISO8601 dari server (string)"
  },

  "_field_to_db_mapping": {
    "title":      "→ template_name (templates) | ad_name (advertisements) | title (agendas)",
    "content":    "→ content (news) | value alias (config)",
    "media_type": "→ template_type (templates) | ad_type (advertisements) | media_type (agendas)",
    "media_path": "→ file_path (templates/advertisements) | media_path (agendas)",
    "key+value":  "→ key + value (config)"
  },

